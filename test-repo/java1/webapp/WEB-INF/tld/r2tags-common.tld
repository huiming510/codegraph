	<!--	【r2:file】	-->
	<tag>
		<description>
			【input type="file"】タグを生成.

			<![CDATA[
			strutsの【html:file】タグがベースです。<br>
			【r2:file】タグを利用する場合、このタグで囲む【s:form】タグではenctype属性に、
			multipart/form-data」を指定することが必要です。
			<br>
			ファイルアップロード関連に関しては、
			<a href="http://struts.wasureppoi.com/taglib/03_file.html" target="_blank">http://struts.wasureppoi.com/taglib/03_file.html</a><br>
			<a href="http://struts.wasureppoi.com/util/01_upload.html"  target="_blank">http://struts.wasureppoi.com/util/01_upload.html</a><br>
			を参照してください。
			]]>
		</description>
		<name>file</name>
		<tag-class>org.apache.struts.taglib.html.FileTag</tag-class>
		<body-content>scriptless</body-content>
		<attribute>
			<description>
			<![CDATA[
			propertyで指定した名称が &lt;input type=&quot;file&quot;&gt;  タグのname属性にセットされます。必須項目です。
			]]>
			</description>
			<name>property</name>
			<required>true</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<description>
			スコープから取得するname属性名称。multiboxタグの場合にはネストが深いようなケース以外は
			あまり想定されない。
			</description>
			<name>name</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<description>
			ボタンに表示する文字列です。
			</description>
			<name>value</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<description>
				MessageResourcesオブジェクトが利用するコンテキスト属性キー。
			</description>
			<name>bundle</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>indexed</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<description>
				取り扱うファイルタイプを指定する。
			</description>
			<name>accept</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<description>
				<![CDATA[
				エラーが発生した場合に、入力フィールドに設定する style 属性の値を指定します。
				   <br>
				&lt;r2:text property=&quot;hoge&quot; size=&quot;10&quot;errorStyle=&quot;background-color:red&quot; /&gt;
				   <br>
				というように記載することでエラーがあった項目のみスタイルを変更することができる。
				]]>
			</description>
			<name>errorStyle</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<description>
			エラーが発生した場合に、入力フィールドに設定する class 属性の値を指定します。
			</description>
			<name>errorStyleClass</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<description>
			エラーが発生した場合に、入力フィールドに設定する id 属性の値を指定します。
			</description>
			<name>errorStyleId</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<description>
			JSP内で同じ名前のプロパティ名の入力フィールドが存在する場合に、強調するフィールドを判別するために使用します。
			この属性を省略した場合は Globals.ERROR_KEY が使用されます。
			<![CDATA[
			エラーキーに関しては、<a href="http://struts.wasureppoi.com/taglib/04_errorkey.html" target="_blank">
			ここ</a>を参照
			]]>
			</description>
			<name>errorKey</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>accesskey</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>alt</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
