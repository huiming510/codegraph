		<example>
		【アクション側の定義】
		public List prefDtoList;
		public String radioChk;

		【JSP】
		&lt;logic:iterate id=&quot;dto&quot; name=&quot;prefDtoList&quot;&gt;
			　&lt;r2:multibox property=&quot;radioChk&quot; idName=&quot;dto&quot; value=&quot;prefCd&quot;/&gt;&lt;r2:write name=&quot;dto&quot; property=&quot;prefName&quot;/&gt;
		&lt;/logic:iterate&gt;
		【実行結果】
		&lt;input name=&quot;radioChk&quot; value=&quot;01&quot; type=&quot;checkbox&quot;&gt; 北海道 &lt;br&gt;
		&lt;input name=&quot;radioChk&quot; value=&quot;02&quot; type=&quot;checkbox&quot;&gt; 東京 &lt;br&gt;

		</example>
	</tag>

	<!--	【r2:submit】	-->
	<tag>
		<description>
			【input type="submit"】タグ出力時に利用.

			<![CDATA[
			strutsの【html:submit】タグがベース.ただし、body-contentはempty属性に変更しています。
			【r2:submit】タグと【input type="submit"】タグの違いは、bundle、indexedなどの特殊なタグが利用できるかどうかだけ
			です。
			デザインHTML上はみえないが、JSPとしては見えるという2WayHTML的な利用方法が想定されます。
			]]>
	</description>
		<name>submit</name>
		<tag-class>org.apache.struts.taglib.html.SubmitTag</tag-class>
		<body-content>empty</body-content>
		<attribute>
			<description>
			propertyで指定した名称が &lt;input type=&quot;submit&quot;&gt;  タグの
			name属性にセットされる。
			</description>
			<name>property</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<description>
				value属性がセットされる。ボタン名称
			</description>
			<name>value</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<description>
				MessageResourcesオブジェクトが利用するコンテキスト属性キー。
			</description>
			<name>bundle</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<description>
				<![CDATA[
				logic:iterate(r2:iterate)タグと併用した際に、そのインデックス値を
				&lt;input type=&quot;submit&quot;&gt;タグのname属性に設定する。
				 ]]>
				 <![CDATA[
				 <br>
				name=name[0] ,name=name[1]のようなイメージで連番がふられる。ただし、あまり利用用途が
				思い当たらない。
				 ]]>
			</description>
			<name>indexed</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>accesskey</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>alt</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>altKey</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>disabled</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>onblur</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>onchange</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>onclick</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>ondblclick</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>onfocus</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>onkeydown</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>onkeypress</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>onkeyup</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>onmousedown</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>onmousemove</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>onmouseout</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>onmouseover</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>onmouseup</name>
			<required>false</required>
