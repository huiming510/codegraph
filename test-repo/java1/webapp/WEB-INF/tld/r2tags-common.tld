		【JSP】&lt;r2:submit-image property=&quot;hoge&quot; src=&quot;images/btn_touroku.gif&quot;/&gt;
		【実行結果】&lt;input name=&quot;hoge&quot; src=&quot;images/btn_touroku.gif&quot; type=&quot;image&quot;/&gt;

		【JSP】&lt;r2:path&gt;&lt;r2:submit-image property=&quot;hoge&quot; src=&quot;images/btn_touroku.gif&quot;/&gt;&lt;/r2:path&gt;
		【実行結果】&lt;input name=&quot;hoge&quot; src=&quot;/r2framework-web/taglib/r2tutorial/images/btn_touroku.gif&quot; type=&quot;image&quot;/&gt;
		</example>
