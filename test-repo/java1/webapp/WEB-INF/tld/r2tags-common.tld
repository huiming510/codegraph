	<!--	【r2:password】	-->
	<tag>
		<description>
		password出力時に指定.

		<![CDATA[
		<br>
		strutsの【html:password】からソースレベルでの拡張はしていないが
		body-contentの指定をemptyに変更し､タグの中に文字列の入力をできないようにしている。
		]]>
		</description>
		<name>password</name>
		<tag-class>org.apache.struts.taglib.html.PasswordTag</tag-class>
		<body-content>empty</body-content>
		<attribute>
			<description>
			<![CDATA[
			propertyで指定した名称が &lt;input type=&quot;password&quot;&gt;  タグの
			name属性にセットされる。またproperty属性でセットされた文字列でスコープから
			変数が取得できたケースにはそれが&lt;input type=&quot;password&quot;&gt;タグの
			value属性(＝フィールドの初期値）としてセットされる。
			(ただし、r2:passwordタグでvalue属性が指定されているケースはそちらが優先される）
			]]>
			</description>
			<name>property</name>
			<required>true</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<description>
			スコープから取得するname属性名称。DTOやMAPの文字列をvalue値の初期値として取得したい
			ようなケースに、スコープのオブジェクト名称を取得するような用途で利用される用途が想定
			される。
			</description>
			<name>name</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>autocomplete</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<description>
			<![CDATA[
			&lt;input type=&quot;password&quot;&gt;タグのvalue属性の初期値(＝フィールドの初期値)
			としてセットされる値。propertyで取得される値よりも優先順位が高い。
			]]>
			</description>
			<name>value</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<description>
				MessageResourcesオブジェクトが利用するコンテキスト属性キー。
			</description>
			<name>bundle</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<description>
				<![CDATA[
				logic:iterate(r2:iterate)タグと併用した際に、そのインデックス値を
				&lt;input type=&quot;password&quot;&gt;タグのname属性に設定する。
				 ]]>
				 <![CDATA[
				 <br>
				name=name[0] ,name=name[1]のようなイメージで連番がふられる。ただし、あまり利用用途が
				思い当たらない。
				 ]]>
			</description>
			<name>indexed</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<description>
				<![CDATA[
				エラーが発生した場合に、入力フィールドに設定する style 属性の値を指定します。
				   <br>
				&lt;r2:password property=&quot;hoge&quot; errorStyle=&quot;background-color:red&quot; /&gt;
				   <br>
				というように記載することでエラーがあった項目のみスタイルを変更することができる。
				]]>
			</description>
			<name>errorStyle</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<description>
			エラーが発生した場合に、入力フィールドに設定する class 属性の値を指定します。
			</description>
			<name>errorStyleClass</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<description>
			エラーが発生した場合に、入力フィールドに設定する id 属性の値を指定します。
			</description>
			<name>errorStyleId</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<description>
			JSP内で同じ名前のプロパティ名の入力フィールドが存在する場合に、強調するフィールドを判別するために使用します。
			この属性を省略した場合は Globals.ERROR_KEY が使用されます。
			<![CDATA[
			エラーキーに関しては、<a href="http://struts.wasureppoi.com/taglib/04_errorkey.html" target="_blank">
			ここ</a>を参照
			]]>
			</description>
			<name>errorKey</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
