	<!--	【r2:button】	-->
	<tag>
		<description>
			【input type="button"】出力時に利用.
			<![CDATA[
			strutsの【html:button】タグがベース.
			ただし、body-contentはempty属性に変更しています。
			【r2:button】タグと【input type="button"】タグの違いは、bundle、indexedなどの特殊なタグが利用できるかどうかだけ
			です。
			デザインHTML上はみえないが、JSPとしては見えるという2WayHTML的な利用方法が想定されます。
			]]>
		</description>
		<name>button</name>
		<tag-class>org.apache.struts.taglib.html.ButtonTag</tag-class>
		<body-content>empty</body-content>
		<attribute>
			<description>
			<![CDATA[
			propertyで指定した名称が &lt;input type=&quot;button&quot;&gt;  タグの
			name属性にセットされる。
			]]>
			</description>
			<name>property</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<description>
				value属性がセットされる。ボタン名称
			</description>
			<name>value</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
