	<!--	【r2:link】	-->
	<tag>
		<description>
		SASTRUTS対応のアンカーの生成です.

		<![CDATA[
 		StrutsのLinkTagを以下のような拡張したR2LinkTagを用いています。
 		<li>URL文字列　SAStruts対応。末尾の.doを削除する</li>
 		<li>URLランダム文字列付与対応。　～URL末尾にランダムな文字列を付与する。</li>
 		<li>URLPattern対応。SAStrutsのURLPatternに対応して、{}で囲まれた文字列を置換する。.でつながるネストすたプロパティにも対応</li>
 		<li>actionMethod属性の追加。アクション名を記載しなくてもメソッド名だけでアクション名を補完する</li>

 		基本的にはaction属性を指定したので問題ないと思われる（それ以外は未検証）。なおSASTRUTSの場合、
 		action属性には、CONTEXTパスを除いたURLを記載する。actionMethod属性を追加しアクションクラスを
 		記載せずメソッド名だけでパスを補完する機能拡張も追加した。
		]]>
		</description>
		<name>link</name>
		<!-- <tag-class>org.apache.struts.taglib.html.LinkTag</tag-class>  -->
		<tag-class>r2framework.web.taglib.r2.R2LinkTag</tag-class>
		<body-content>scriptless</body-content>
		<attribute>
			<description>
			contextPathを除くURLを記載する。{}で囲まれた文字列を置換するSAStrutsのURLPattern表記も表現可能。
			</description>
			<name>action</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<description>
			末尾にランダム文字列を指定するようなオプション。デフォルトはfalseだが、trueにすれば
			URL末尾にランダム文字列を付与する。
			</description>
			<name>randamizeUrl</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
			<type>java.lang.Boolean</type>
		</attribute>
		<attribute>
			<description>
			actionクラスのメソッド名のみ記載することで、アクションクラスのパスなどを補完して表示させる。
			同一ユースケース（＝つまり同一のアクションクラスに存在している）の場合のみ有効。
			action属性との共存は不可。
			</description>
			<name>actionMethod</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<description>
			trueにすれば、HTTPS付きの完全なURLで出力する(SSL対応）
			</description>
			<name>fullURLwithSSL</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
			<type>java.lang.Boolean</type>
		</attribute>
		<attribute>
			<description>
			trueにすれば、HTTP付きの完全なURLで出力する(SSL非対応）
			</description>
			<name>fullURLnoSSL</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
			<type>java.lang.Boolean</type>
		</attribute>
		<attribute>
			<description>
				パスのプレフィックスを有効にする.
			</description>
			<name>pathPrefix</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
			<type>java.lang.Boolean</type>
		</attribute>
		<attribute>
			<description>
				パスのプレフィックスのキー名.
			</description>
			<name>pathPrefixKey</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
			<type>java.lang.String</type>
		</attribute>
		<attribute>
			<name>accesskey</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>module</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>anchor</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>forward</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>href</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>indexed</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>indexId</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>bundle</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>linkName</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>name</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>onblur</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>onclick</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>ondblclick</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>onfocus</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>onkeydown</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>onkeypress</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>onkeyup</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>onmousedown</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>onmousemove</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>onmouseout</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>onmouseover</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>onmouseup</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>page</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>paramId</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>paramName</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>paramProperty</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>paramScope</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>property</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>scope</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>style</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>styleClass</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>styleId</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>tabindex</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>target</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>title</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>titleKey</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>transaction</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>useLocalEncoding</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>label</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<example>
		【JSP】
		&lt;r2:link action=&quot;/taglib/r2tutorial/urlPatternLink/{urlPattern}&quot;&gt;URLPaternでの画面遷移&lt;/r2:link&gt;
		&lt;r2:link action=&quot;/taglib/r2tutorial/&quot; randamizeUrl=&quot;true&quot;&gt;ランダムパラメータつき画面遷移&lt;/r2:link&gt;
		&lt;r2:link action=&quot;/taglib/r2tutorial/urlPatternLink/{urlPattern.nestedProperty}&quot;&gt;NESTしたプロパティにも対応&lt;/r2:link&gt;

		【出力結果】
		&lt;a href=&quot;/r2framework-web/taglib/r2tutorial/urlPatternLink/urlPatternTestString&quot;&gt;URLPaternでの画面遷移&lt;/a&gt;
		&lt;a href=&quot;/r2framework-web/taglib/r2tutorial/?__r=3.07.09.07.07.01.05.05.02.04.0&quot;&gt;ランダムパラメータつき画面遷移&lt;/a&gt;
		&lt;a href=&quot;/r2framework-web/taglib/r2tutorial/urlPatternLink/nestURLPatternString&quot;&gt;NESTしたプロパティにも対応&lt;/a&gt;
		</example>
	</tag>



	<!--	【r2:rewrie】	-->
	<tag>
		<description>
		javascript用のアンカーの生成（SaStruts対応).

		<![CDATA[
		下記のExampleの例のようにJavascriptでリンク先を動的に切り替えるようなケースで、r2:linkタグと組み合わせて
		利用します。<br>
		基本的には【r2:link】で実施している拡張と同等の拡張を実施しています(r2link参照）。
		<br>
 		基本的にはaction属性を指定したので問題ないと思われる（それ以外は未検証）。なおSASTRUTSの場合、
 		action属性には、CONTEXTパスを除いたURLを記載します。

		]]>
		</description>
		<name>rewrite</name>
		<!-- <tag-class>org.apache.struts.taglib.html.RewriteTag</tag-class> -->
		<tag-class>r2framework.web.taglib.r2.R2RewriteTag</tag-class>
		<body-content>empty</body-content>
		<attribute>
			<description>
			contextPathを除くURLを記載する。{}で囲まれた文字列を置換するSAStrutsのURLPattern表記も表現可能。
			</description>
			<name>action</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<description>
			末尾にランダム文字列を指定するようなオプション。デフォルトはfalseだが、trueにすれば
			URL末尾にランダム文字列を付与する。
			</description>
			<name>randamizeUrl</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
			<type>java.lang.Boolean</type>
		</attribute>
		<attribute>
			<description>
			actionクラスのメソッド名のみ記載することで、アクションクラスのパスなどを補完して表示させる。
			同一ユースケース（＝つまり同一のアクションクラスに存在している）の場合のみ有効。
			action属性との共存は不可。
			</description>
			<name>actionMethod</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>module</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>anchor</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>forward</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>href</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>name</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>page</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>paramId</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>paramName</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>paramProperty</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>paramScope</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>property</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>scope</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>transaction</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>useLocalEncoding</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<example>
		【JSP】
		&lt;s:form&gt;
		&lt;script type=&quot;text/javascript&quot;&gt;
		&lt;!--

		function submit_form(){
			　　form = window.document.forms[0];
			　　form.action = &quot;&lt;r2:rewrite action=&quot;/taglib/r2tutorial/posttransition&quot;/&gt;&quot;;
			　　form.submit();
			　　return false;
		}

		// --&gt;
		&lt;/script&gt;
		　&lt;r2:link href=&quot;#&quot; onclick=&quot;submit_form()&quot;&gt;&lt;c:out value=&quot;バリデータの走る画面へ遷移&quot;/&gt;&lt;/r2:link&gt;
		&lt;/s:form&gt;

		【出力結果】
		&lt;form name=&quot;taglib_r2tutorialActionForm&quot; method=&quot;post&quot; action=&quot;/r2framework-web/taglib/r2tutorial/&quot;&gt;
		&lt;script type=&quot;text/javascript&quot;&gt;
		&lt;!--

		function submit_form(){
		　　form = window.document.forms[0];
		　　form.action = &quot;/r2framework-web/taglib/r2tutorial/posttransition&quot;;
		　　form.submit();
		　　return false;
		}
		// --&gt;
		&lt;/script&gt;
		　　&lt;a href=&quot;#&quot; onclick=&quot;submit_form()&quot;&gt;バリデータの走る画面へ遷移&lt;/a&gt;
		&lt;/form&gt;

		</example>
	</tag>
	<!--	【r2:frame】	-->
	<tag>
		<description>
		フレームの際に利用.
		<![CDATA[
		フレームを利用する際に用います。基本的にはr2:linkで実施している拡張と同等の拡張を実施しています(r2link参照）。
 		基本的にはaction属性を指定したので問題ないと思われる（それ以外は未検証）。なおSASTRUTSの場合、
 		action属性には、CONTEXTパスを除いたURLを記載します。

 		なお、詳細は、
 		<a href="http://struts.wasureppoi.com/taglib/00_taglib.html" target="_blank">こちら</a>を参照。

		]]>
		</description>
		<name>frame</name>
		<tag-class>org.apache.struts.taglib.html.FrameTag</tag-class>
		<body-content>JSP</body-content>
		<attribute>
			<description>
			contextPathを除くURLを記載する。{}で囲まれた文字列を置換するSAStrutsのURLPattern表記も表現可能。
			</description>
			<name>action</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<description>
			末尾にランダム文字列を指定するようなオプション。デフォルトはfalseだが、trueにすれば
			URL末尾にランダム文字列を付与する。
			</description>
			<name>randamizeUrl</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
			<type>java.lang.Boolean</type>
		</attribute>
		<attribute>
			<description>
			actionクラスのメソッド名のみ記載することで、アクションクラスのパスなどを補完して表示させる。
			同一ユースケース（＝つまり同一のアクションクラスに存在している）の場合のみ有効。
			action属性との共存は不可。
			</description>
			<name>actionMethod</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>bundle</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>module</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>anchor</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>forward</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>frameborder</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>frameName</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>href</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>longdesc</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>marginheight</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>marginwidth</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>name</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>noresize</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>page</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>paramId</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>paramName</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>paramProperty</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>paramScope</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>property</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>scope</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>scrolling</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>style</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>styleClass</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>styleId</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>title</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>titleKey</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>transaction</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
	</tag>


	<!--	【r2:messages】	-->
	<tag>
		<description>
		メッセージ出力時に利用.

		<![CDATA[
		<br>
		strutsの【html:errors】タグを利用.
		機能はhtml:errorsと同様ですが、エラーでないのメッセージを出力する用途の想定です。
		属性指定なしだとすべてのメッセージが出力され、属性指定をすると特定のメッセージだけが出力されます。
		property属性を指定すると指定したプロパティのメッセージのみ出力できます。
		strutsの【html:messages】に該当するタグは【r2:messagesIterate】となりますので、ご注意下さい。
		なお、リソースファイルに指定するheader・footer・prefix・suffixの各種名称は、以下の通りです。
		 <ul>
		  <li>messages.header</li>
		  <li>messages.footer</li>
		  <li>messages.prefix</li>
		  <li>messages.suffix</li>
		 </li>
		 </ul>
		]]>
		</description>
		<name>messages</name>
		<tag-class>r2framework.web.taglib.r2.R2MessagesTag</tag-class>
		<body-content>empty</body-content>
		<attribute>
			<description>
				特定のプロパティーのメッセージを出力した場合に指定します。
			</description>
			<name>property</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<description>
			メッセージ出力前に1回出力されるヘッダーの指定です
			</description>
			<name>header</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<description>
			メッセージが全て出力後に1回出力されるフッターの指定です
			</description>
			<name>footer</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<description>
			各メッセージの最初に出力されるプレフィックスです
			</description>
			<name>prefix</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<description>
			各メッセージの最後に出力されるサフィックスです
			</description>
			<name>suffix</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<description>
				個別のメッセージを出力したい場合、リソースファイルのキーを指定します。
			</description>
			<name>bundle</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<description>
				個別のメッセージを出力したい場合、メッセージを格納している個別のオブジェクトの名称を指定します。
			</description>
			<name>name</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<description>
				ロケールを指定します。多言語対応する場合等に使用します。
			</description>
			<name>locale</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<description>
				同一のメッセージを複数表示させたくない場合に「true」を指定します。
			</description>
			<name>distinct</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
	</tag>



	<!--	【r2:messagesIterate】	-->
	<tag>
		<description>
			メッセージ・エラーメッセージ出力時に利用.
			<![CDATA[
			strutsの【html:messages】タグを利用。
			似たような機能としてr2:errors、r2:messagesタグが存在しますが、こちらはそれらのタグとは異なり、リソースファイルからヘッダ・フッタ指定を読み込まないため、
			柔軟なレイアウト指定が可能です。
			その代わり、画面ごとの記述量は増えてしまいます。
			]]>
		</description>
		<name>messagesIterate</name>
		<tag-class>org.apache.struts.taglib.html.MessagesTag</tag-class>
		<tei-class>org.apache.struts.taglib.html.MessagesTei</tei-class>
		<body-content>JSP</body-content>
		<attribute>
			<name>id</name>
			<required>true</required>
			<rtexprvalue>false</rtexprvalue>
		</attribute>
		<attribute>
			<name>bundle</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>locale</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>name</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>property</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>header</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>footer</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>message</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
	</tag>

	<!--	【r2:size】-->
	<tag>
		<description>
		配列やコレクションの要素数の取得.
		<![CDATA[
		配列やコレクションの要素数を取得し、名前(idで付与)をつけてpageスコープに定義します。<br>
		r2タグでの独自拡張要素はありませんが、name属性を必須項目とすることでスクリプトレット式
		対応のcollection属性を利用できないようにしています。
		主な利用用途としては、List&lt;Dto&gt;などのオブジェクトの件数を取得するために
		指定します。
		]]>
		</description>
		<name>size</name>
		<tag-class>org.apache.struts.taglib.bean.SizeTag</tag-class>
		<tei-class>org.apache.struts.taglib.bean.SizeTei</tei-class>
		<body-content>empty</body-content>
		<attribute>
			<description>
			結果を格納する変数名です。pageスコープに登録されるのでこの変数名で値を
			取り出すことができます。
			</description>
			<name>id</name>
			<required>true</required>
			<rtexprvalue>false</rtexprvalue>
		</attribute>
		<attribute>
			<description>
			スコープに格納されている出力対象のオブジェクトの名称を
			指定します。
			r2タグリブでは必須項目として定義しなおしました。
			</description>
			<name>name</name>
			<required>true</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<description>
			オブジェクトのプロパティの要素数を取得したい場合に指定します。
			例えば、ネストした要素を取り出したいケースなどに指定します。
			</description>
			<name>property</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>scope</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>collection</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<example>
		｢List&lt;Dto&gt; dtoList｣の件数が10件の場合：
		【JSP】&lt;r2:size id=&quot;cnt&quot; name=&quot;dtoList&quot;/&gt;  &lt;!--←idに変数をセット --&gt;
		件数は&lt;r2:write name=&quot;cnt&quot;/&gt;件です。

		【実行結果】件数は10件です。

		</example>
	</tag>
	<!--【r2:define 】-->
	<tag>
		<description>
			変数名をsetAttribute.
			strutsの【bean:define】タグをそのまま利用している。【r2:define】は
			JSP内で使用する変数名を指定することで、その変数を他の箇所で利用できるようになります。デフォルトだと
			pageスコープの範囲で有効になります。スコープを変えたい場合には、toScopeの設定をおこなってください。
		</description>
		<name>define</name>
		<tag-class>r2framework.web.taglib.r2.R2DefineTag</tag-class>
		<tei-class>org.apache.struts.taglib.bean.DefineTei</tei-class>
		<body-content>empty</body-content>
		<attribute>
			<description>
			JSP内で使用する変数名を指定します。
			</description>
			<name>id</name>
			<required>true</required>
			<rtexprvalue>false</rtexprvalue>
		</attribute>
		<attribute>
			<description>
			変数に格納する値を定義します。
			</description>
			<name>value</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<description>
			現在スコープに登録されている定義対象のオブジェクトの名前を指定します
			</description>
			<name>name</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<description>
			 	Beanのプロパティを指定します。
			</description>
			<name>property</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<description>
			name属性で指定した定義対象のオブジェクトが格納されているセッションのスコープを指定します。 省略時はpage、request、session、applicationの順で検索されます。
			</description>
			<name>scope</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<description>
			 	id属性で指定するBeanを格納するセッションのスコープ。省略時はpageスコープになります。
			</description>
			<name>toScope</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<description>
			idに代入するオブジェクトのクラスを指定します。プリミティブ型の場合はラッパークラスを指定します。
			</description>
			<name>type</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<example>
		【JSP】
		&lt;c:if test=&quot;${var % 2 == 0}&quot;&gt;
			　　&lt;r2:define id=&quot;tblClassAttr&quot; value=&quot;a&quot; toScope=&quot;page&quot;/&gt;
		&lt;/c:if&gt;
		&lt;table class=&quot;${tblClassAttr}&quot;&gt;

		【実行結果】
		&lt;table class=&quot;a&quot;&gt;
		</example>
	</tag>
	<!--【r2:form 】-->
	<tag>
		<description>
			SAstrutsの【s:form】の拡張.

			<![CDATA[
			拡張ポイントは以下
			<li>同期トークン用のhiddenを出力するdivタグにstyle="display:none"を付加</li>
			<li>HTTP/HTTPS付きのURLを出力するオプションを付与する対応</li>
			]]>
		</description>
		<name>form</name>
		<!--tag-class>r2framework.web.taglib.r2.R2FormTag</tag-class-->
		<tag-class>jp.co.rct.jj.base.taglib.JJFormTag</tag-class>
		<body-content>JSP</body-content>
		<attribute>
			<description>
				同一のユースケース内に遷移する場合は省略してよい。別ユースケースへの遷移の場合には、ユースケース名
				(=Action名)から記載する必要がある。
			</description>
			<name>action</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>acceptCharset</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>disabled</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>enctype</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>focus</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>focusIndex</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>method</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>onreset</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>onsubmit</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>readonly</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>scriptLanguage</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>style</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>styleClass</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>styleId</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>target</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>onkeypress</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>onkeyup</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>onkeydown</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<description>
				HTTPS付きの完全URLのFORMタグとする.
			</description>
			<name>fullURLwithSSL</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
			<type>java.lang.Boolean</type>
		</attribute>
		<attribute>
			<description>
				HTTP付きの完全URLのFORMタグとする.
			</description>
			<name>fullURLnoSSL</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
			<type>java.lang.Boolean</type>
		</attribute>
		<attribute>
			<description>
				パスのプレフィックスを有効にする.
			</description>
			<name>pathPrefix</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
			<type>java.lang.Boolean</type>
		</attribute>
		<attribute>
			<description>
				パスのプレフィックスのキー名.
			</description>
			<name>pathPrefixKey</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
			<type>java.lang.String</type>
		</attribute>
	</tag>
	<!--	【r2:responseStatus】	-->
	<tag>
		<description>レスポンスヘッダーにHTTPステータスコードを強制的に設定します。</description>
		<name>responseStatus</name>
		<tag-class>r2framework.web.taglib.r2.R2ResponseStatusTag</tag-class>
		<body-content>empty</body-content>
		<attribute>
			<description>
			 	HTTPステータスコードを指定します。
			</description>
			<name>statusCode</name>
			<required>true</required>
			<rtexprvalue>false</rtexprvalue>
			<type>java.lang.Integer</type>
		</attribute>
		<example>
			・ステータスを404にする場合
			【JSP】&lt;r2:responseStatus statusCode=&quot;404&quot;/&gt;
		</example>
	</tag>
	<!--	【r2:import】	-->
	<tag>
		<description>
		c:importの拡張.
		<![CDATA[
		throwsException属性によって、エラー発生時にExceptionを発生させるかどうかを切り替えられるように設定
		throwsException=falseがデフォルト、trueにすると、ファイルが存在しないときなどのExceptionが発生する
		]]>		</description>
		<name>import</name>
		<tag-class>r2framework.web.taglib.r2.R2ImportTag</tag-class>
		<tei-class>org.apache.taglibs.standard.tei.ImportTEI</tei-class>
		<body-content>JSP</body-content>
		<attribute>
			<description>
				インポートするリソースのURL.
			</description>
			<name>url</name>
			<required>true</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<description>
				リソースに渡す変数名（文字列）.
			</description>
			<name>var</name>
			<required>false</required>
			<rtexprvalue>false</rtexprvalue>
		</attribute>
		<attribute>
			<description>
			変数のスコープ.
			</description>
			<name>scope</name>
			<required>false</required>
			<rtexprvalue>false</rtexprvalue>
		</attribute>
		<attribute>
			<description>
				リソースに渡す変数名（リーダー）.
			</description>
			<name>varReader</name>
			<required>false</required>
			<rtexprvalue>false</rtexprvalue>
		</attribute>
		<attribute>
			<description>
				別コンテキストのリソースを取得する際に指定するコンテキスト名.
			</description>
			<name>context</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<description>
				リソースのエンコーディング.
			</description>
			<name>charEncoding</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<description>
				エラー発生時にExceptionを投げるかどうか.
			</description>
			<name>throwsException</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
			<type>java.lang.Boolean</type>
		</attribute>
		<attribute>
			<description>
				URLの安全性を指定する.
			</description>
			<name>safe</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
			<type>java.lang.Boolean</type>
		</attribute>
	</tag>

	<tag>
		<description>
			Adds a parameter to a containing 'import' tag's URL.
		</description>
		<name>param</name>
		<tag-class>org.apache.taglibs.standard.tag.rt.core.ParamTag</tag-class>
		<body-content>JSP</body-content>
		<attribute>
			<description>
	Name of the query string parameter.
			</description>
			<name>name</name>
			<required>true</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<description>
	Value of the parameter.
			</description>
			<name>value</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
	</tag>

	<!--	【r2:resourceMessage】	-->
	<tag>
		<description>
			プロパティファイルのメッセージやラベルを出力時に利用.
			<![CDATA[
			strutsの【bean:message】タグを利用。
			プロパティファイルから取得した文字列を直接表示します。
			]]>
		</description>
		<name>resourceMessage</name>
		<tag-class>org.apache.struts.taglib.bean.MessageTag</tag-class>
		<body-content>empty</body-content>
		<attribute>
			<name>arg0</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>arg1</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>arg2</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>arg3</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>arg4</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<description>
				MessageResourcesオブジェクトが利用するコンテキスト属性キー。
			</description>
			<name>bundle</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<description>
			<![CDATA[
			メッセージリソースのkeyを指定します。
			]]>
			</description>
			<name>key</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>locale</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>name</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>property</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
		<attribute>
			<name>scope</name>
			<required>false</required>
			<rtexprvalue>true</rtexprvalue>
		</attribute>
	</tag>


</taglib>
