# 应用配置
UPLOAD_DIR=uploads
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:5174

# 知识库解析服务地址（建索引、文档上传解析、QA 检索 POST /qa/ 等）
LINKRAG_SERVER_URL=http://192.168.10.187:8000

# QA 流程服务地址（检索时调用 POST /qa/，不填则用 LINKRAG_SERVER_URL）
QA_SERVICE_URL=http://192.168.10.187:8000

# 智能问答流式对话外部 API 地址（/api/chat/stream-external 代理转发目标，调用外部 /chat/stream）
CHAT_STREAM_URL=http://192.168.10.187:8000

# SQLite 数据库（文件路径，相对路径相对于运行目录）
SQLITE_DATABASE=linkrag.db