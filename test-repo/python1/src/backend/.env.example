# LLM配置
# 支持的provider: openai, azure_openai, anthropic, ollama, zhipu, qwen, mock
LLM_PROVIDER=mock
LLM_MODEL=gpt-3.5-turbo
LLM_API_KEY=your-api-key
LLM_API_BASE=
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048

# Azure OpenAI专用
AZURE_DEPLOYMENT=
AZURE_API_VERSION=2024-02-01

# 应用配置
UPLOAD_DIR=uploads
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# 一体化发布（无 Nginx）可开启：由 FastAPI 直接托管前端 dist
# SERVE_FRONTEND=true
# FRONTEND_DIST_DIR=./frontend_dist

# 解析服务 / QA 流程服务地址（检索时调用 POST /qa/）
LINKRAG_SERVER_URL=http://192.168.10.187:8000
QA_SERVICE_URL=http://192.168.10.187:8000   # 不填则用 LINKRAG_SERVER_URL

# 多轮流式对话外部 API 地址（后端代理转发目标）
# CHAT_STREAM_URL=http://192.168.10.187:8000

# 解析服务写入的 ES 索引名；若希望 ES 里看到 index=test123，则设为 LINKRAG_ES_INDEX=test123（默认 poc）
# LINKRAG_ES_INDEX=poc
# Elasticsearch 连接（可选，与 config.yml elasticsearch 对应；也可在系统管理 - ES环境配置 中填写）
# ELASTICSEARCH_URL=http://192.168.10.187:9200
# ELASTICSEARCH_USERNAME=elastic
# ELASTICSEARCH_PASSWORD=
# Embedding 服务（解析时向量化，与 config.yml embedding 一致可防解析报错；也可在 ES环境配置 页面填写）
# EMBEDDING_BASE_URL=http://192.168.10.187:5002/v1/embeddings
# EMBEDDING_MODEL=Qwen3-Embedding-0.6B

# 数据库配置（二选一）
# 1) 推荐：显式 DATABASE_URL（支持 SQLite / PostgreSQL）
# SQLite 示例：
# DATABASE_URL=sqlite+aiosqlite:///D:/rag/linkrag_sdd/src/backend/linkrag.db
# PostgreSQL 示例：
# DATABASE_URL=postgresql+asyncpg://postgres:password@127.0.0.1:5432/linkrag

# 2) 兼容模式：未设置 DATABASE_URL 时，使用 SQLITE_DATABASE
SQLITE_DATABASE=linkrag.db

# ========== 各LLM配置示例 ==========

# OpenAI
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4
# LLM_API_KEY=sk-xxx

# Azure OpenAI
# LLM_PROVIDER=azure_openai
# LLM_API_KEY=xxx
# LLM_API_BASE=https://your-resource.openai.azure.com
# AZURE_DEPLOYMENT=your-deployment-name

# Anthropic Claude
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-3-sonnet-20240229
# LLM_API_KEY=sk-ant-xxx

# Ollama (本地)
# LLM_PROVIDER=ollama
# LLM_MODEL=llama2
# LLM_API_BASE=http://localhost:11434

# 智谱AI
# LLM_PROVIDER=zhipu
# LLM_MODEL=glm-4
# LLM_API_KEY=xxx

# 通义千问
# LLM_PROVIDER=qwen
# LLM_MODEL=qwen-turbo
# LLM_API_KEY=xxx
