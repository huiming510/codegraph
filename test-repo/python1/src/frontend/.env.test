# 测试环境
VITE_APP_NODE_ENV=test

# 应用标题
VITE_APP_TITLE=RAG 知识库

# 公共基础路径
VITE_APP_PUBLIC_PATH=/

# 路由模式 hash | history
VITE_APP_ROUTER_MODE=hash

# 测试环境接口基础地址
VITE_APP_API_BASE_URL=/api

# 压缩算法 gzip | brotli | none
VITE_APP_BUILD_COMPRESS=none

# 打包是否去除 console、debug
VITE_APP_DROP_CONSOLE_DEBUG=true

# 打包压缩后是否删除源文件
VITE_APP_BUILD_COMPRESS_DELETE_ORIGIN_FILE=false
