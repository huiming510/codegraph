# 复制为 .env.development 或 .env.production 后按需修改
# 开发: cp .env.example .env.development
# 生产: 在 CI/部署时设置以下变量或使用 .env.production

VITE_APP_NODE_ENV=development
VITE_APP_TITLE=RAG 知识库
VITE_APP_PUBLIC_PATH=/
VITE_APP_ROUTER_MODE=hash
VITE_APP_API_BASE_URL=/api
VITE_APP_PORT=5174
VITE_OPEN=true
VITE_APP_PROXY=true
VITE_APP_PROXY_TARGET=http://localhost:8000

# 生产/测试环境额外可选
# VITE_APP_BUILD_COMPRESS=gzip
# VITE_APP_DROP_CONSOLE_DEBUG=true
# VITE_APP_BUILD_COMPRESS_DELETE_ORIGIN_FILE=false
