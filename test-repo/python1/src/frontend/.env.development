# 开发环境
VITE_APP_NODE_ENV=development

# 应用标题（浏览器标题、登录页等）
VITE_APP_TITLE=LinkRAG

# 公共基础路径
VITE_APP_PUBLIC_PATH=./

# 路由模式 hash | history
VITE_APP_ROUTER_MODE=hash

# 开发环境接口基础地址（会通过 vite proxy 转发到后端）
VITE_APP_API_BASE_URL=/api

# 开发服务器端口
VITE_APP_PORT=5174

# 启动后是否自动打开浏览器
VITE_OPEN=true

# 是否开启代理（将 /api 转发到后端）
VITE_APP_PROXY=true

# Vite 代理目标（前端 /api -> 后端）；连接远程后端时改为如 http://192.168.10.187:8000
VITE_APP_PROXY_TARGET=http://localhost:8000
